# Application
NODE_ENV=development
LOG_LEVEL=debug
API_BASE_URL=http://localhost:3000

# Database (Supabase / RDS PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# JWT
JWT_SECRET=your-jwt-secret-at-least-64-characters-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-64-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# AWS 
AWS_REGION=ap-south-1
CLOUDWATCH_LOG_GROUP=/tuk-tuk-api/dev
